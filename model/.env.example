# ═══════════════════════════════════════════════════════════
# CloudBurst — Environment Variables (copy to .env)
# ═══════════════════════════════════════════════════════════
# Copy this file to .env and fill in your API keys.
# The .env file is expected inside the model/ directory.
# ═══════════════════════════════════════════════════════════

# ── Weather API ───────────────────────────────────────────
WEATHER_API_KEY=your_weatherapi_key_here

# ── Email Alerts (Gmail SMTP) ─────────────────────────────
SENDER_EMAIL=your_email@gmail.com
SENDER_PASS=your_app_password_here

# ── Twilio SMS Alerts ─────────────────────────────────────
TWILIO_SID=your_twilio_account_sid
TWILIO_AUTH=your_twilio_auth_token
TWILIO_PHONE=+1234567890  # Your Twilio phone number

# ── Optional: Groq LLM (for multi-agent system) ───────────
GROQ_API_KEY=your_groq_api_key

