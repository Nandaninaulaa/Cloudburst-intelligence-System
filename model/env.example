# ─────────────────────────────────────────────────────────
# GeoAI CloudBurst — Environment Variables
# ─────────────────────────────────────────────────────────

# ✅ PRIMARY: Groq API — FREE, no credit card needed
# Get key in 30 seconds: https://console.groq.com → API Keys → Create
# Uses Llama-3 70B — fast and accurate
GROQ_API_KEY=gsk_YOUR_FREE_GROQ_KEY_HERE

# ⚡ OPTIONAL: Anthropic Claude (paid fallback — only if you have credits)
ANTHROPIC_API_KEY=sk-ant-YOUR_KEY_HERE

# Weather API (WeatherAPI.com — free tier)
WEATHER_API_KEY=YOUR_WEATHERAPI_KEY_HERE

# Email alerts (Gmail App Password)
SENDER_EMAIL=youremail@gmail.com
SENDER_PASS=your_gmail_app_password

# Twilio SMS (optional)
TWILIO_SID=YOUR_TWILIO_SID
TWILIO_AUTH=YOUR_TWILIO_AUTH_TOKEN
TWILIO_PHONE=+1XXXXXXXXXX
